
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isNotBanned() {
      return !exists(/databases/$(database)/documents/artifacts/studio-3405255876-f647c/public/data/bannedUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && isNotBanned();
    }

    function isAdmin() {
      let profilePath = /databases/$(database)/documents/artifacts/studio-3405255876-f647c/public/data/public_profiles/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email == 'apersson508@gmail.com' ||
        (exists(profilePath) && get(profilePath).data.role in ['Huvudadmin', 'Moderator'])
      );
    }

    match /artifacts/studio-3405255876-f647c/public/data {
      match /cars/{licensePlate} {
        allow read: if true;
        allow write: if isSignedIn() && isNotBanned();
        allow delete: if isAdmin();
      }
      
      match /vehicleHistory/{licensePlate}/logs/{logId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBanned();
        allow update: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.creatorId);
        allow delete: if isAdmin() || (
          isOwner(resource.data.creatorId) || 
          (isOwner(resource.data.ownerId) && resource.data.approvalStatus == 'pending')
        );
      }

      match /pending_approvals/{notificationId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isNotBanned();
        allow update, delete: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.workshopId) || resource == null;
      }

      match /workshop_notifications/{notificationId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || isOwner(resource.data.workshopId) || resource == null;
      }

      match /public_listings/{listingId} {
        allow read: if true;
        allow write: if isSignedIn() && isNotBanned();
        allow delete: if isAdmin() || isOwner(resource.data.ownerId);
      }

      match /public_profiles/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }

      match /bannedUsers/{userId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      match /workshops/{workshopId} {
        allow read: if true;
        allow write: if isOwner(workshopId) || isAdmin();
        match /servicedCars/{carId} {
          allow read, write: if isSignedIn() && isNotBanned();
        }
      }

      match /conversations/{conversationId} {
        allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isNotBanned();
        allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
        allow delete: if isAdmin();
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && isNotBanned();
          allow delete: if isAdmin();
        }
      }
      
      match /odometer_corrections/{id} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    match /artifacts/studio-3405255876-f647c/users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isNotBanned() {
      let appId = 'studio-3405255876-f647c';
      return !exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/bannedUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && isNotBanned();
    }

    function isSystemOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'apersson508@gmail.com'
      );
    }

    function isModerator() {
      let appId = 'studio-3405255876-f647c';
      return isSignedIn() && (
        isSystemOwner() ||
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/public_profiles/$(request.auth.uid)).data.role in ['Huvudadmin', 'Moderator']
      );
    }

    match /artifacts/{appId}/public/data {
      match /cars/{licensePlate} {
        allow read: if true;
        allow write: if isSignedIn() && isNotBanned();
      }
      match /vehicleHistory/{licensePlate}/logs/{logId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBanned();
        allow update, delete: if isSignedIn() && isNotBanned() && (
          request.auth.uid == resource.data.creatorId || 
          isModerator()
        );
      }
      match /odometer_corrections/{plate} {
        allow read: if isModerator();
        allow create: if isSignedIn() && isNotBanned();
        allow update, delete: if isModerator();
      }
      match /pending_approvals/{notificationId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isNotBanned() && request.auth.uid == request.resource.data.workshopId;
        allow update, delete: if isSignedIn() && isNotBanned() && (
          request.auth.uid == resource.data.ownerId || 
          request.auth.uid == resource.data.workshopId ||
          isModerator()
        );
      }
      match /public_listings/{listingId} {
        allow read: if true;
        allow write, delete: if isSignedIn() && isNotBanned();
      }
      match /public_profiles/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) || isModerator();
      }
      match /bannedUsers/{userId} {
        allow read: if isSignedIn();
        allow write: if isModerator();
      }
      match /workshops/{workshopId} {
        allow read: if true;
        allow write: if isOwner(workshopId) || isModerator();
        match /servicedCars/{carId} {
          allow read, write: if isSignedIn() && isNotBanned();
        }
      }
      match /conversations/{conversationId} {
        allow read, write: if isSignedIn() && isNotBanned() && (request.auth.uid in resource.data.participants || !exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/conversations/$(conversationId)));
        match /messages/{messageId} {
          allow read, create: if isSignedIn() && isNotBanned();
        }
      }
    }

    match /artifacts/{appId}/users/{userId} {
      allow read, write: if isOwner(userId) || isModerator();
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isModerator();
      }
    }
  }
}